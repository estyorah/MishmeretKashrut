<script>
  // ---- Dummy directory data ----
  const establishments = [
    {name:"Lev Grill & Bar", category:"Restaurant", location:"Lakewood, NJ", id:"MSH-1042", inspected:"2026-05-18", status:"active"},
    {name:"Sephardic Bites Catering", category:"Caterer", location:"Brooklyn, NY", id:"MSH-0871", inspected:"2026-06-02", status:"active"},
    {name:"Tov Market & Grocery", category:"Grocery", location:"Deal, NJ", id:"MSH-0334", inspected:"2026-06-10", status:"active"},
    {name:"Aroma Bakery", category:"Bakery", location:"Far Rockaway, NY", id:"MSH-0509", inspected:"2026-04-29", status:"active"},
    {name:"Kedem Foods Manufacturing", category:"Manufacturer", location:"Elizabeth, NJ", id:"MSH-0125", inspected:"2026-03-14", status:"active"},
    {name:"Mizrahi Family Catering", category:"Caterer", location:"Edgewater, NJ", id:"MSH-0998", inspected:"2026-06-15", status:"active"},
    {name:"Yaffa Pizza & Grill", category:"Restaurant", location:"Forest Hills, NY", id:"MSH-0772", inspected:"2026-05-30", status:"pending"},
    {name:"Levana's Sweets", category:"Bakery", location:"Lawrence, NY", id:"MSH-0611", inspected:"2026-02-21", status:"active"},
    {name:"Daniel's Fish Market", category:"Grocery", location:"Lakewood, NJ", id:"MSH-0246", inspected:"2026-06-05", status:"active"},
    {name:"Gan Eden Events", category:"Caterer", location:"Teaneck, NJ", id:"MSH-0890", inspected:"2026-01-09", status:"pending"}
  ];

  function statusBadge(s){
    return s === "active"
      ? '<span class="stamp active">● Active</span>'
      : '<span class="stamp pending">● Renewal pending</span>';
  }

  function renderDirectory(list){
    const body = document.getElementById('dirBody');
    if(list.length === 0){
      body.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--ink-soft);padding:24px;">No establishments match your search.</td></tr>';
      return;
    }
    body.innerHTML = list.map(e => `
      <tr>
        <td><span class="est-name">${e.name}</span></td>
        <td><span class="est-cat">${e.category}</span></td>
        <td>${e.location}</td>
        <td><span class="cert-id">${e.id}</span></td>
        <td>${e.inspected}</td>
        <td>${statusBadge(e.status)}</td>
      </tr>
    `).join('');
  }

  function filterDirectory(){
    const q = document.getElementById('dirSearch').value.toLowerCase();
    const cat = document.getElementById('dirCategory').value;
    const filtered = establishments.filter(e =>
      (e.name.toLowerCase().includes(q) || e.location.toLowerCase().includes(q) || e.id.toLowerCase().includes(q)) &&
      (cat === "" || e.category === cat)
    );
    renderDirectory(filtered);
  }

  renderDirectory(establishments);

  // ---- Verify lookup in hero ----
  function runVerify(){
    const val = document.getElementById('verifyInput').value.trim().toLowerCase();
    const results = document.getElementById('verifyResults');
    if(!val){
      results.innerHTML = '<div class="verify-empty">Enter an establishment name or certification ID to verify its status.</div>';
      return;
    }
    const matches = establishments.filter(e =>
      e.name.toLowerCase().includes(val) || e.id.toLowerCase().includes(val)
    );
    if(matches.length === 0){
      results.innerHTML = '<div class="verify-empty">No certified establishment found matching "' + val.replace(/</g,"") + '".</div>';
      return;
    }
    results.innerHTML = matches.slice(0,4).map(e => `
      <div class="verify-hit">
        <div>
          <div class="vh-name">${e.name}</div>
          <div class="vh-meta">${e.category} · ${e.location} · <span class="mono">${e.id}</span></div>
        </div>
        ${statusBadge(e.status)}
      </div>
    `).join('');
  }

  document.getElementById('verifyInput').addEventListener('keyup', function(e){
    if(e.key === 'Enter') runVerify();
  });
</script>

